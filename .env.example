DATABASE_URL=postgresql+psycopg://policyai:policyai@localhost:5432/policyai
POSTGRES_DB=policyai
POSTGRES_USER=policyai
POSTGRES_PASSWORD=policyai
UPLOAD_DIR=uploads
AUTH_SECRET=replace_with_a_long_random_local_secret
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=policy_chunks
EMBEDDING_MODEL=all-MiniLM-L6-v2
ENABLE_LOCAL_EMBEDDINGS=false
FRONTEND_ORIGIN=http://localhost:5173

# Optional Gemini API integration for later synthesis work.
# Copy this file to .env and fill in your own key locally.
GEMINI_API_KEY=your_google_ai_studio_key
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.2
